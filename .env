# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/myapp

# API
API_HOST=0.0.0.0
API_PORT=2530
API_PREFIX=/api

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d

# CORS (comma separated)
CORS_ORIGINS=http://localhost:8888,http://localhost:3000,http://localhost:5173

# Runtime
ENVIRONMENT=development
