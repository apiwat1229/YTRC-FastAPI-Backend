# ─── Database ────────────────────────────────────────────────────────────────
# Production:  postgresql+asyncpg://postgres:<PASS>@db:5432/ytrc_prod
# Staging:     postgresql+asyncpg://postgres:<PASS>@db:5432/ytrc_staging
# Local:       postgresql+asyncpg://postgres:postgres@localhost:5433/myapp
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/myapp

# Postgres container env (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=myapp

# ─── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ─── API ─────────────────────────────────────────────────────────────────────
# Production port: 2530 | Staging port: 2531
API_HOST=0.0.0.0
API_PORT=2530
API_PREFIX=/api

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-use-a-random-64-char-hex-string
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ─── CORS (comma separated) ──────────────────────────────────────────────────
# Production:  https://yourdomain.com,https://app.yourdomain.com
# Staging:     http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:8888,http://localhost:3000,http://localhost:5173

# ─── Runtime ─────────────────────────────────────────────────────────────────
# Values: development | staging | production
# production → disables /docs, /redoc, /openapi.json
ENVIRONMENT=development
